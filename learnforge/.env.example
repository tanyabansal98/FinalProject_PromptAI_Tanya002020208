# ── Mode: demo | api | ollama ──
# demo = No API needed, uses pre-generated content (for demos and testing)
# api  = Uses OpenAI API (needs OPENAI_API_KEY)
# ollama = Uses local Ollama server (needs Ollama running)
LEARNFORGE_MODE=demo

# ── OpenAI (only needed for api mode) ──
OPENAI_API_KEY=sk-...

# ── HuggingFace (only needed for fine-tuning) ──
HF_TOKEN=hf_...

# ── Ollama (only needed for ollama mode) ──
OLLAMA_MODEL=llama3
OLLAMA_BASE_URL=http://localhost:11434

# ── Fine-tuned model ──
USE_FINETUNED=false
